cmd_backup() {
    need_game
    [[ -f "$ACTIVE_FILE" ]] || die "Chưa có ACTIVE để sao lưu."

    mkdir -p "$BACKUP_DIR"

    local target
    target="$BACKUP_DIR/SkillTextTable_EN_$(date +%Y%m%d_%H%M%S).json"

    cp -a "$ACTIVE_FILE" "$target"

    echo "Đã sao lưu:"
    echo "$target"
}

cmd_open() {
    need_game
    mkdir -p "$CONFIG_DIR"
    xdg-open "$CONFIG_DIR" >/dev/null 2>&1 &
}

cmd_exports() {
    need_game
    mkdir -p "$EXPORT_ROOT"
    xdg-open "$EXPORT_ROOT" >/dev/null 2>&1 &
}

cmd_log() {
    need_game
    [[ -f "$LOG_FILE" ]] || die "Không thấy LogOutput.log"

    grep -iE \
        "BD2 Vietnamese Skill Text|BD2 Skill Text Exporter|BD2 Vietnamese Tooltip|BD2 UI Text Capture|Loaded.*Vietnamese|Patched methods|tooltip translation|translation|replacement failed|could not patch|error|exception" \
        "$LOG_FILE" |
    tail -n 120
}

case "${1:-help}" in
    clear) cmd_clear ;;
    pull) cmd_pull ;;
    raw) cmd_show_raw ;;
    active) cmd_show_active ;;
    editraw) cmd_edit_raw ;;
    edit) cmd_edit_active ;;
    check) cmd_check ;;
    push) cmd_push ;;
    status) cmd_status ;;
    backup) cmd_backup ;;
    path) latest_capture ;;
    open) cmd_open ;;
    exports) cmd_exports ;;
    log) cmd_log ;;
    tooltip-pull|tpull) cmd_tooltip_pull ;;
    tooltip-edit|tedit) cmd_tooltip_edit ;;
    tooltip-push|tpush) cmd_tooltip_push ;;
    tooltip-raw|traw) cmd_tooltip_show_raw ;;
    tooltip-active|tactive) cmd_tooltip_show_active ;;
    tooltip-path|tpath) latest_tooltip_capture ;;
    skill-workflow|skill) cmd_skill_workflow ;;
    tooltip-workflow|tooltip) cmd_tooltip_workflow ;;
    help|-h|--help) show_help ;;
    *) die "Lệnh không hợp lệ. Dùng: bd2 help" ;;
esac
