        cp -a "$TOOLTIP_ACTIVE_FILE" "$backup"
        echo "Đã sao lưu ACTIVE tooltip:"
        echo "$backup"
    fi

    python3 - "$TOOLTIP_RAW_FILE" "$TOOLTIP_ACTIVE_FILE" <<'PY'
import json
import os
import sys
from pathlib import Path

raw_path = Path(sys.argv[1])
active_path = Path(sys.argv[2])

with raw_path.open(encoding="utf-8") as file:
    raw = json.load(file)

if active_path.exists():
    with active_path.open(encoding="utf-8") as file:
        active = json.load(file)
else:
    active = {}

if not isinstance(raw, dict) or not isinstance(active, dict):
    raise SystemExit("RAW và ACTIVE tooltip phải là JSON object.")

for key, value in raw.items():
    if not isinstance(key, str) or not isinstance(value, dict):
        raise SystemExit("Mỗi tooltip phải có dạng key → object.")

    title = value.get("title")
    info = value.get("info")

    if not isinstance(title, str) or not isinstance(info, str):
        raise SystemExit(
            f"Tooltip {key!r} phải có title và info dạng chuỗi."
        )

active.update(raw)

ordered = {
    key: active[key]
    for key in sorted(active, key=str.casefold)
}

temporary_path = active_path.with_suffix(active_path.suffix + ".tmp")
temporary_path.write_text(
    json.dumps(ordered, ensure_ascii=False, indent=2) + "\n",
    encoding="utf-8",
)
os.replace(temporary_path, active_path)

print(f"Đã gộp {len(raw)} tooltip RAW vào ACTIVE.")
print(f"Tổng ACTIVE tooltip: {len(ordered)}.")
print(active_path)
PY

    echo
    echo "Quay lại game: F6 → đóng và mở lại popup."
}

