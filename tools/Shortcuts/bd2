validate_json_file() {
    local file="$1"
    local label="$2"

    if [[ ! -f "$file" ]]; then
        echo "$label: chưa có"
        return
    fi

    python3 - "$file" "$label" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
label = sys.argv[2]

with path.open(encoding="utf-8") as file:
    data = json.load(file)

if not isinstance(data, dict):
    raise SystemExit(f"{label}: phải là JSON object")

for key, value in data.items():
    if not isinstance(key, str) or not isinstance(value, str):
        raise SystemExit(
            f"{label}: mọi ID và nội dung phải là chuỗi"
        )

print(f"{label}: JSON hợp lệ, {len(data)} khóa")
PY
}

cmd_check() {
    need_game
    validate_json_file "$RAW_FILE" "RAW"
    validate_json_file "$ACTIVE_FILE" "ACTIVE"
}

cmd_push() {
    need_game
    mkdir -p "$CONFIG_DIR" "$BACKUP_DIR"

    [[ -f "$RAW_FILE" ]] || die "Chưa có RAW. Chạy: bd2pull"

    validate_json_file "$RAW_FILE" "RAW"

    if [[ -f "$ACTIVE_FILE" ]]; then
        local backup
        backup="$BACKUP_DIR/SkillTextTable_EN_$(date +%Y%m%d_%H%M%S).json"
        cp -a "$ACTIVE_FILE" "$backup"
        echo "Đã sao lưu ACTIVE:"
        echo "$backup"
    fi

    python3 - "$RAW_FILE" "$ACTIVE_FILE" <<'PY'
import json
import os
import sys
from pathlib import Path

raw_path = Path(sys.argv[1])
active_path = Path(sys.argv[2])

with raw_path.open(encoding="utf-8") as file:
    raw = json.load(file)

if active_path.exists():
    with active_path.open(encoding="utf-8") as file:
        active = json.load(file)
else:
    active = {}

if not isinstance(raw, dict) or not isinstance(active, dict):
    raise SystemExit("RAW và ACTIVE đều phải là JSON object.")

active.update(raw)

def sort_key(value: str):
    base, _, suffix = value.partition(":")
    return (int(base) if base.isdigit() else 10**30, suffix)

ordered = {
    key: active[key]
    for key in sorted(active, key=sort_key)
}

temporary_path = active_path.with_suffix(active_path.suffix + ".tmp")
temporary_path.write_text(
    json.dumps(ordered, ensure_ascii=False, indent=4) + "\n",
    encoding="utf-8"
)
os.replace(temporary_path, active_path)

print(f"Đã gộp {len(raw)} khóa RAW vào ACTIVE.")
print(f"Tổng ACTIVE: {len(ordered)} khóa.")
print(active_path)
PY

    echo
    echo "RAW vẫn được giữ song song và game không đọc nó:"
    echo "$RAW_FILE"
    echo
    echo "Quay lại game: nhấn F6, đóng và mở lại trang skill."
}


cmd_tooltip_pull() {
    need_game
    mkdir -p "$CONFIG_DIR" "$BACKUP_DIR"

    local latest
    latest="$(latest_tooltip_capture)"

    if [[ -f "$TOOLTIP_RAW_FILE" ]]; then
        cp -a \
            "$TOOLTIP_RAW_FILE" \
            "$BACKUP_DIR/TooltipText_EN.raw_$(date +%Y%m%d_%H%M%S).json"
    fi

    python3 - "$latest" "$TOOLTIP_RAW_FILE" <<'PY'
import json
import os
import sys
from pathlib import Path

source_path = Path(sys.argv[1])
output_path = Path(sys.argv[2])

with source_path.open(encoding="utf-8") as file:
    rows = json.load(file)

if not isinstance(rows, list):
    raise SystemExit("UI capture phải là JSON array.")

groups = {}

for row in rows:
    if not isinstance(row, dict):
        continue

    path = row.get("path", "")
    text = row.get("text", "")

    if (
        not isinstance(path, str)
        or not isinstance(text, str)
        or "/SkillInfoTooltip(Clone)/" not in path
    ):
        continue

    field = None
    base = None

    for suffix, name in (
        ("/Text - Title", "title"),
        ("/Text - Info", "info"),
    ):
        if path.endswith(suffix):
            base = path[: -len(suffix)]
            field = name
            break

    if field is None or base is None:
        continue

    groups.setdefault(base, {})[field] = text

result = {}

for base in sorted(groups):
    item = groups[base]
    title = item.get("title", "").strip()
    info = item.get("info", "")

    if not title or not info:
        continue

    result[title] = {
        "title": title,
        "info": info,
    }

if not result:
    raise SystemExit(
        "Không tìm thấy tooltip nào trong capture. "
        "Hãy giữ popup mở rồi nhấn F7."
    )

temporary_path = output_path.with_suffix(output_path.suffix + ".tmp")
temporary_path.write_text(
    json.dumps(result, ensure_ascii=False, indent=2) + "\n",
    encoding="utf-8",
)
os.replace(temporary_path, output_path)

print(f"Đã lấy {len(result)} tooltip vào RAW:")
print(output_path)
PY

    echo
    echo "ACTIVE tooltip vẫn giữ nguyên:"
    echo "$TOOLTIP_ACTIVE_FILE"
}

