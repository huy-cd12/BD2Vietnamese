#!/usr/bin/env bash
set -euo pipefail

GAME_DEFAULT="$HOME/.steam/debian-installation/steamapps/compatdata/3667336694/pfx/drive_c/Neowiz/Browndust2/Browndust2_10000001"
GAME="${GAME:-$GAME_DEFAULT}"

EXPORT_ROOT="$GAME/BepInEx/exports/BD2SkillText"
CONFIG_DIR="$GAME/BepInEx/config/BD2Vietnamese"

ACTIVE_FILE="$CONFIG_DIR/SkillTextTable_EN.json"
RAW_FILE="$CONFIG_DIR/SkillTextTable_EN.raw.json"

TOOLTIP_EXPORT_ROOT="$GAME/BepInEx/exports/BD2UITextCapture"
TOOLTIP_ACTIVE_FILE="$CONFIG_DIR/TooltipText_EN.json"
TOOLTIP_RAW_FILE="$CONFIG_DIR/TooltipText_EN.raw.json"

LOG_FILE="$GAME/BepInEx/LogOutput.log"
BACKUP_DIR="$HOME/BD2_translation_backup"

die() {
    echo "LỖI: $*" >&2
    exit 1
}

need_game() {
    [[ -d "$GAME" ]] || die "Không thấy thư mục game: $GAME"
}

latest_capture() {
    need_game

    local latest
    latest="$(
        find "$EXPORT_ROOT" \
            -maxdepth 1 \
            -type d \
            -name "skill_capture_*" \
            -printf '%T@ %p\n' 2>/dev/null |
        sort -nr |
        head -n 1 |
        cut -d' ' -f2-
    )"

    [[ -n "$latest" ]] || die "Chưa có capture nào. Trong game: F11 → F9 → mở skill → F9."
    printf '%s\n' "$latest"
}

latest_tooltip_capture() {
    need_game

    local latest
    latest="$(
        find "$TOOLTIP_EXPORT_ROOT" \
            -maxdepth 1 \
            -type f \
            -name "ui_capture_*.json" \
            -printf '%T@ %p\n' 2>/dev/null |
        sort -nr |
        head -n 1 |
        cut -d' ' -f2-
    )"

    [[ -n "$latest" ]] ||
        die "Chưa có UI capture. Mở popup tooltip rồi nhấn F7 một lần."

    printf '%s\n' "$latest"
}

view_raw_file() {
    local file="$1"
    local label="$2"

    [[ -f "$file" ]] || die "Không thấy file: $file"

    echo
    echo "============================================================"
    echo "$label"
    echo "============================================================"
    echo

    if command -v less >/dev/null 2>&1 && [[ -t 1 ]]; then
        less -R "$file"
    else
        cat "$file"
    fi

    echo
}

